@model IEnumerable<Personnel>

<div class="container">
    <table class='table table-striped'>
        <tr>
            <th>Id</th>
            <th>Name</th>
        </tr>
        @if (Model != null)
        {
            @foreach (var personnel in Model)
            {
                <tr>
                    <td>@personnel.Id</td>
                    <td>@personnel.Name</td>
                </tr>
            }
        }
    </table>
</div>
