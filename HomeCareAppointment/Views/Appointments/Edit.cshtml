@model HomeCareAppointment.Models.Appointment

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Appointment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AppointmentId" />

            <div class="form-group">
                <label class="control-label">Patient</label>
                <input class="form-control" value="@ViewBag.PatientName" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="control-label"></label>
                <input asp-for="Notes" class="form-control" />
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="AvailableDayId" class="control-label">Appointment (Date - Personnel)</label>
                <select asp-for="AvailableDayId" class="form-control" asp-items="ViewBag.AvailableDayId"></select>
                <span asp-validation-for="AvailableDayId" class="text-danger"></span>
            </div>

            <!-- Small static label informing user about changing the slot (no JS) -->
            <p class="text-muted small" style="margin-top:6px;">
                Selecting a different slot will change the appointment to the chosen date/personnel.
            </p>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="ManageAdmin">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
