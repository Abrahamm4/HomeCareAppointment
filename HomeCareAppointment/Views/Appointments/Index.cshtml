@model IEnumerable<HomeCareAppointment.Models.AvailableDay>

@{
    ViewData["Title"] = "Book Appointment";
}

<h1>Book Appointment</h1>

<div class="d-flex flex-column align-items-start gap-2 mb-3">

    <!-- Admin manage (later restrict to Admin role) -->
    <a asp-controller="Appointments" asp-action="ManageAdmin"
       class="btn btn-outline-primary w-50">
        Manage Bookings (Admin)
    </a>

    <!-- Patient manage with dropdown (later replaced by logged-in patient id) -->
    <form asp-controller="Appointments" asp-action="ManagePatient" method="post" class="w-50">
        <div class="input-group">
            <select class="form-select" name="patientId" required>
                <option value="">-- Select Patient --</option>
                @foreach (var patient in (ViewBag.Patients as List<HomeCareAppointment.Models.Patient>) ?? Enumerable.Empty<HomeCareAppointment.Models.Patient>())
                {
                    <option value="@patient.PatientId">@patient.Name</option>
                }
            </select>
            <button type="submit" class="btn btn-outline-secondary">
                Manage Bookings (Patient)
            </button>
        </div>
    </form>

</div>


<table class="table">
    <thead>
        <tr>
            <th>Personnel</th>
            <th>Date</th>
            <th>Start</th>
            <th>End</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var day in Model)
        {
            <tr>
                <td>@day.Personnel?.Name</td>
                <td>@day.Date.ToShortDateString()</td>
                <td>@day.StartTime</td>
                <td>@day.EndTime</td>
                <td>
                    @if (day.Appointment == null)
                    {
                        <form asp-controller="Appointments" asp-action="Create" method="get">
                            <input type="hidden" name="availableDayId" value="@day.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">Book</button>
                        </form>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Booked</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
