@model IEnumerable<HomeCareAppointment.Models.Appointment>

@{
    ViewData["Title"] = "Manage";
}

<h1>Manage</h1>

@{
    var patientMode = ViewData["PatientMode"] as bool? ?? false;
    var selectedPatient = ViewData["SelectedPatient"] as HomeCareAppointment.Models.Patient;
    ViewData["Title"] = patientMode
        ? (selectedPatient != null ? $"Appointments for {selectedPatient.Name}" : "Patient Appointments")
        : "Manage Bookings (Admin)";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@ViewData["Title"]</h2>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No appointments found.
    </div>
}
else
{
    <table class="table table-bordered table-striped align-middle">
        <thead class="table-light">
            <tr>
                <th>Personnel</th>
                <th>Date</th>
                <th>Start</th>
                <th>End</th>
                @if (!patientMode)
                {
                    <th>Patient</th>
                }
                <th style="width:220px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appt in Model)
            {
                <tr>
                    <td>@appt.Personnel?.Name</td>
                    <td>@appt.AvailableDay?.Date.ToShortDateString()</td>
                    <td>@appt.AvailableDay?.StartTime.ToString(@"hh\:mm")</td>
                    <td>@appt.AvailableDay?.EndTime.ToString(@"hh\:mm")</td>

                    @if (!patientMode)
                    {
                        <td>@appt.Patient?.Name</td>
                    }

                    <td>
                        <a asp-action="Details" asp-route-id="@appt.AppointmentId" class="btn btn-sm btn-outline-secondary">
                            Details
                        </a>

                        <a asp-action="Edit" asp-route-id="@appt.AppointmentId" class="btn btn-sm btn-warning ms-1">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@appt.AppointmentId" class="btn btn-sm btn-danger btn-app-sm ms-1">Delete</a>

                    </td>
                </tr>
            }
        </tbody>
    </table>
}
