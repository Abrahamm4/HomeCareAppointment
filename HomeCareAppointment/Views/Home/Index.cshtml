@{
 ViewData["Title"] = "Home";
}

<div class="py-5 bg-light">
 <div class="container">
 <div class="row justify-content-center">
 <div class="col-lg-8 text-center">
 <h1 class="display-5 fw-semibold">HomeCare Appointment</h1>
 <p class="lead text-muted mt-3">Simple scheduling for homecare: publish available days and book appointments.</p>
 <div class="mt-4 d-flex gap-3 justify-content-center">
 <a class="btn btn-primary btn-lg" asp-controller="Appointments" asp-action="Index">Book appointment</a>
 <a class="btn btn-outline-secondary btn-lg" asp-controller="AvailableDays" asp-action="Create">Create available day</a>
 </div>
 </div>
 </div>
 </div>
</div>
